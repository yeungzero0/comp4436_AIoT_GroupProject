        "type": "function",
        "z": "fc85e8173cba9109",
        "name": "function 1",
        "func": "// Access the prediction data from the incoming payload\nconst predictionData = msg.payload;\n\n// Initialize the HTML table\nlet html = '<table border=\"1\" style=\"width: 100%; border-collapse: collapse; text-align: center;\">';\nhtml += '<tr><th>Recommendation</th><th>Details</th></tr>';\n\n// Add rows for the relevant data\nhtml += `<tr>\n            <td>Recommendations DateTime</td>\n            <td>${predictionData.prediction_datetime}</td>\n          </tr>`;\nhtml += `<tr>\n            <td>Recommended Pricing</td>\n            <td>${predictionData.recommendations.pricing}</td>\n          </tr>`;\nhtml += `<tr>\n            <td>Reservation</td>\n            <td>${predictionData.recommendations.reservation}</td>\n          </tr>`;\n\n// Close the table\nhtml += '</table>';\n\n// Set the formatted HTML as the new payload\nmsg.payload = html;\n\nreturn msg;",
