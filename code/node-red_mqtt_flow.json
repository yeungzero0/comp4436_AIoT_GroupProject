    {
        "id": "788e0ea0591a9405",
        "type": "function",
        "z": "fc85e8173cba9109",
        "name": "Peak Usage Times",
        "func": "// Initialize an array to hold the formatted strings\nlet formattedData = [];\n\n// Access the peak_hours array from the incoming payload\nconst peakHours = msg.payload.peak_hours;\n\n// Loop through each hour object and format the string\npeakHours.forEach(hourData => {\n    const formattedString = `Hour ${hourData.hour}: (Total occupancy rate: ${hourData.total_occupancy_rate}%)`;\n    formattedData.push(formattedString);\n});\n\n// Join the formatted strings into a single message\nmsg.payload = formattedData.join('<br>');\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
