    {
        "id": "580fa9b931a084fd",
        "type": "function",
        "z": "fc85e8173cba9109",
        "name": "Daily Performing",
        "func": "// Split the incoming string into lines\nconst lines = msg.payload.split('\\n');\n\n// Create an HTML table\nlet html = '<table border=\"1\"><tr><th>Record Date</th><th>Space 1 Occupancy Rate</th><th>Space 2 Occupancy Rate</th><th>Space 3 Occupancy Rate</th><th>Avg Occupancy Rate</th><th>Total Occupied</th></tr>';\n\n// Loop through each line and add it to the table\nfor (let i = 1; i < lines.length; i++) { // Start from 1 to skip the header\n    const columns = lines[i].trim().split(/\\s+/);\n    if (columns.length > 0) {\n        html += '<tr>';\n        columns.forEach(column => {\n            html += `<td>${column}</td>`;\n        });\n        html += '</tr>';\n    }\n}\nhtml += '</table>';\n\n// Set the formatted HTML as the new payload\nmsg.payload = html;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 380,
        "y": 440,
        "wires": [
            [
                "03f1070d411edccc"
            ]
        ]
    },
