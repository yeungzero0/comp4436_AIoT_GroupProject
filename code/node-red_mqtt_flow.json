        "name": " Recurring Occupancy",
        "func": "// Access the occupancy data from the incoming payload\nconst occupancyData = msg.payload;\n\n// Format the output string\nconst outputString = `Average WeekDay Occupancy: ${occupancyData.weekday_occupancy.toFixed(2)}%<br>Average WeekEnd Occupancy: ${occupancyData.weekend_occupancy.toFixed(2)}%`;\n\n// Set the formatted string as the new payload\nmsg.payload = outputString;\n\nreturn msg;",
