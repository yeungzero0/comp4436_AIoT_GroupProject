    {
        "id": "507005233df2ff3a",
        "type": "function",
        "z": "fc85e8173cba9109",
        "name": "Dynamic Pricing",
        "func": "// Initialize the HTML table\nlet html = '<table border=\"1\" style=\"width: 100%; border-collapse: collapse;\">';\nhtml += '<tr><th>Hour</th><th>Occupancy Rate (%)</th><th>Recommended Price (HKD)</th><th>Strategy</th></tr>';\n\n// Access the array from the incoming payload\nconst pricingData = msg.payload;\n\n// Loop through each object in the pricing data array\npricingData.forEach(item => {\n    html += `<tr>\n                <td>${item.hour}</td>\n                <td>${item.occupancy_rate.toFixed(1)}</td>\n                <td>${item.recommended_price.toFixed(1)}</td>\n                <td>${item.strategy}</td>\n              </tr>`;\n});\n\n// Close the table\nhtml += '</table>';\n\n// Set the formatted HTML as the new payload\nmsg.payload = html;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
